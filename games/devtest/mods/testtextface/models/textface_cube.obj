# Cube mesh for text_face testing
# UVs oriented so text reads left-to-right on each face

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vt 0 0
vt 1 0
vt 1 1
vt 0 1

vn  0  0 -1
vn  0  0  1
vn  0  1  0
vn  0 -1  0
vn  1  0  0
vn -1  0  0

# front (-Z) facing viewer
f 2/1/1 1/2/1 4/3/1 3/4/1
# back (+Z)
f 5/1/2 6/2/2 7/3/2 8/4/2
# top (+Y)
f 8/1/3 7/2/3 3/3/3 4/4/3
# bottom (-Y)
f 1/1/4 2/2/4 6/3/4 5/4/4
# right (+X)
f 6/1/5 2/2/5 3/3/5 7/4/5
# left (-X)
f 1/1/6 5/2/6 8/3/6 4/4/6
